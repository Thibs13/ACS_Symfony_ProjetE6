<!DOCTYPE html>

<title>Utilisateur</title>

{% block body %}
    <h1>Utilisateur</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ utilisateur.id }}</td>
            </tr>
            <tr>
                <th>Nom</th>
                <td>{{ utilisateur.nom }}</td>
            </tr>
            <tr>
                <th>Prenom</th>
                <td>{{ utilisateur.prenom }}</td>
            </tr>
            <tr>
                <th>Login</th>
                <td>{{ utilisateur.login }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_utilisateur_read') }}">Retour</a>

    <a href="{{ path('app_utilisateur_update', {'id': utilisateur.id}) }}">Modifier</a>

    {{ include('utilisateur_crud/_delete_form.html.twig') }}
{% endblock %}