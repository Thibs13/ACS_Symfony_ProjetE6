  <div class="kpi blue fu"><div class="kpi-icon">⚽</div><div class="kpi-val"><?= $bp ?></div><div class="kpi-lbl">Buts marqués</div></div>
  <div class="kpi red fu2"><div class="kpi-icon">🥅</div><div class="kpi-val"><?= $bc ?></div><div class="kpi-lbl">Buts encaissés</div></div>
  <div class="kpi fu3"><div class="kpi-icon">📊</div><div class="kpi-val"><?= $pct>0?"$pct%":'—' ?></div><div class="kpi-lbl">% Victoires</div></div>
  <div class="kpi gold fu"><div class="kpi-icon">↕️</div>
    <div class="kpi-val"><?= ($bp-$bc)>=0?'+'.($bp-$bc):$bp-$bc ?></div><div class="kpi-lbl">Diff. buts</div>
  </div>
</div>

<!-- Prochain match -->
<?php if($prochain): ?>
<div class="card mb6 fu" style="border-color:var(--b3);background:linear-gradient(135deg,var(--s2),var(--s1))">
  <div class="card-hd">
    <span class="card-title">⏭ Prochain match</span>
    <span class="tsm tw3"><?= h($prochain['comp']??'') ?><?= $prochain['journee']?" · J{$prochain['journee']}":'' ?></span>
  </div>
  <div class="card-bd">
    <div class="flex flex-ic gap4" style="flex-wrap:wrap">
      <div class="fbig" style="font-size:32px">TFC</div>
      <div style="font-size:24px;color:var(--w3)">vs</div>
      <div class="fbig" style="font-size:32px"><?= h($prochain['adv']) ?></div>
      <div class="tsm tw3" style="margin-left:auto;text-align:right">
        📅 <?= date('d/m/Y à H\hi', strtotime($prochain['date_match'])) ?><br>
        <?= $prochain['domicile'] ? '🏠 Domicile' : '✈️ Extérieur' ?>
      </div>
    </div>
  </div>
</div>
<?php endif ?>

<div class="g2 mb6">
  <!-- Bilan D/E -->
  <div class="card fu">
    <div class="card-hd"><span class="card-title">🏠 Domicile / Extérieur</span></div>
    <div class="card-bd">
      <div class="g2" style="gap:10px;margin-bottom:14px">
