<?php
// index.php — Dashboard principal
// BDD : tfc_historique (colonnes réelles)
require_once 'includes/config.php';
$nav = 'dashboard'; $pageTitle = 'Dashboard';
$db  = getDB();
$sid = $GLOBALS['sid'];

// Bilan saison
$bilan = $db->prepare("
    SELECT COUNT(*) j,
        SUM(resultat='V') v, SUM(resultat='N') n, SUM(resultat='D') d,
        SUM(score_tfc) bp, SUM(score_adverse) bc,
        SUM(resultat='V')*3 + SUM(resultat='N') pts,
        ROUND(AVG(spectateurs)) moy_spec
    FROM matchs WHERE saison_id=? AND score_tfc IS NOT NULL");
$bilan->execute([$sid]); $b = $bilan->fetch();

// Infos saison
$saison = $db->prepare("SELECT s.*,st.nom stade_nom FROM saisons s
    LEFT JOIN stades st ON st.id=s.stade_id WHERE s.id=?");
$saison->execute([$sid]); $saison = $saison->fetch();

// Dernier classement enregistré
$cls = $db->prepare("SELECT * FROM classement WHERE saison_id=? ORDER BY journee DESC LIMIT 1");
$cls->execute([$sid]); $cl = $cls->fetch();

// Prochain match (sans score)
$next = $db->prepare("
    SELECT m.*,a.nom adv,c.nom comp
    FROM matchs m
    JOIN adversaires a ON a.id=m.adversaire_id
    LEFT JOIN competitions c ON c.id=m.competition_id
    WHERE m.saison_id=? AND m.score_tfc IS NULL AND m.date_match >= NOW()
    ORDER BY m.date_match ASC LIMIT 1");
$next->execute([$sid]); $prochain = $next->fetch();

// Derniers matchs joués
$dm = $db->prepare("
    SELECT m.*,a.nom adv
    FROM matchs m
    JOIN adversaires a ON a.id=m.adversaire_id
    WHERE m.saison_id=? AND m.score_tfc IS NOT NULL
    ORDER BY m.date_match DESC LIMIT 6");
$dm->execute([$sid]); $derniers = $dm->fetchAll();

// Top buteurs (depuis stats_joueur_match — table réelle)
$bu = $db->prepare("
    SELECT j.nom, j.prenom, j.poste_principal,
        (SELECT jp.numero_maillot FROM joueurs_passages jp WHERE jp.joueur_id=j.id AND jp.actif=1 LIMIT 1) AS numero,
        SUM(sm.buts) buts,
        SUM(sm.passes_decisives) passes,
        SUM(sm.minutes_jouees) mins,
        COUNT(DISTINCT sm.match_id) mj
    FROM stats_joueur_match sm
    JOIN joueurs j ON j.id=sm.joueur_id
    JOIN matchs m ON m.id=sm.match_id
    WHERE m.saison_id=?
    GROUP BY j.id
    HAVING buts>0
    ORDER BY buts DESC, passes DESC
    LIMIT 8");
$bu->execute([$sid]); $buteurs = $bu->fetchAll();

// Bilan domicile / extérieur
$bde = $db->prepare("
    SELECT
        SUM(domicile=1 AND resultat='V') vd, SUM(domicile=1 AND resultat='N') nd, SUM(domicile=1 AND resultat='D') dd,
        SUM(domicile=0 AND resultat='V') ve, SUM(domicile=0 AND resultat='N') ne, SUM(domicile=0 AND resultat='D') de
    FROM matchs WHERE saison_id=? AND score_tfc IS NOT NULL");
$bde->execute([$sid]); $bilande = $bde->fetch();

// Forme récente (5 derniers)
$forme = $db->prepare("
    SELECT resultat FROM matchs
    WHERE saison_id=? AND resultat IS NOT NULL
    ORDER BY date_match DESC LIMIT 5");
$forme->execute([$sid]); $forme5 = array_reverse($forme->fetchAll());

$v=(int)($b['v']??0); $n=(int)($b['n']??0); $d=(int)($b['d']??0);
$j=(int)($b['j']??0); $bp=(int)($b['bp']??0); $bc=(int)($b['bc']??0);
$pts=(int)($b['pts']??0); $pct=$j>0?round($v/$j*100):0;

require_once 'includes/header.php';
?>

<!-- Forme récente -->
<?php if($forme5): ?>
<div class="flex flex-ic gap2 mb6" style="flex-wrap:wrap">
  <span class="tsm tw3" style="margin-right:4px">Forme récente :</span>
  <?php foreach($forme5 as $f): ?>
  <span class="rb <?= $f['resultat'] ?>" style="width:32px;height:32px;font-size:13px"><?= $f['resultat'] ?></span>
  <?php endforeach ?>
  <?php if($cl): ?>
  <span style="margin-left:16px;padding:4px 14px;background:var(--s2);border:1px solid var(--b);border-radius:20px;font-size:12px">
