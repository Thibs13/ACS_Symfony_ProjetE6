<form class="stage-delete-form" method="post" action="{{ path('app_stage_delete', {'id': stage.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce stage ?');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ stage.id) }}">
    <button class="btn-danger">Supprimer</button>
</form>
