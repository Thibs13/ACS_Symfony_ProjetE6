<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Inscription | Campus La Chataigneraie</title>
    <link rel="stylesheet" href="{{ asset('CSS/inscription.css') }}">
</head>
<body>
    <div class="accueil-wrapper">
        <div class="login-card">
            <header class="logo-container">
                <img src="{{ asset('Image/campus-logo.png') }}" alt="Logo du Campus" />
            </header>

            {# Gestion des messages d'erreur et de succes #}
            {% if erreur is defined and erreur %}
                <div class="alert alert-error">
                    {{ erreur }}
                </div>
            {% endif %}

            {% if succes is defined and succes %}
                <div class="alert alert-success">
                    {{ succes }}
                </div>
            {% endif %}

            {# Debut du formulaire #}
            {{ form_start(form) }}
                <div class="form-group">
                    {{ form_label(form.login, 'Login :') }}
                    {{ form_widget(form.login) }}
                </div>

                <div class="form-group">
                    {{ form_label(form.MotDePasse, 'Mot de passe :') }}
                    {{ form_widget(form.MotDePasse) }}
                </div>

                <div class="form-group">
                    {{ form_label(form.Nom, 'Nom :') }}
                    {{ form_widget(form.Nom) }}
                </div>

                <div class="form-group">
                    {{ form_label(form.Prenom, 'Prenom :') }}
                    {{ form_widget(form.Prenom) }}
                </div>

                {# On n'affiche pas form.Save ici car on utilise notre propre bouton stylise #}
                {% do form.Save.setRendered %}

                <button type="submit" class="btn-submit">
                    S'inscrire
                </button>
            {{ form_end(form) }}

            <div class="links-container">
                <a href="{{ path('app_accueil') }}">Retour a la connexion</a>
            </div>
        </div>
    </div>
</body>
</html>