<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Stages - La Chataigneraie</title>
    <link rel="stylesheet" href="{{ asset('CSS/dashboard.css') }}">
    <link rel="stylesheet" href="{{ asset('CSS/etudiant.css') }}">
</head>
<body>

<aside class="sidebar">
    <div class="sidebar-logo">
        <div class="logo-badge">
            <img src="{{ asset('Image/campus-logo.png') }}" alt="Logo Campus La Chataigneraie" />
        </div>
        <h2>La Chataigneraie</h2>
        <p>Suivi des stages</p>
    </div>

    {% include 'navigation.html.twig' with {
                'namePage' : 'suiviVisite' 
                } %}

    <div class="sidebar-footer">
        <a href="{{ path('app_deco') }}" class="btn-deco">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/>
                <polyline points="16 17 21 12 16 7"/>
                <line x1="21" y1="12" x2="9" y2="12"/>
            </svg>
            Deconnexion
        </a>
    </div>
</aside>

    <main class="main">
        <div class="page-header-flex">
            <div>
                <h1>Suivi Global des Stages</h1>
                <p>Vue administrateur : répartition des enseignants par stage.</p>
            </div>
        </div>

        <div class="section-card table-wrapper">
            <table class="students-table">
                <thead>
                    <tr>
                        <th>Étudiant</th>
                        <th>Entreprise</th>
                        <th>Prof. Suivi</th>
                        <th>Prof. Visite</th>
                    </tr>
                </thead>
                <tbody>
                {% for stage in stages %}
                    <tr>
                        <td><strong>{{ stage.ETUID.ETUNom }}</strong> {{ stage.ETUID.ETUPrenom }}</td>
                        <td>{{ stage.ENTID.ENTNom }}</td>
                        <td>{{ stage.EnseignantSuivi ? stage.EnseignantSuivi.nom ~ ' ' ~ stage.EnseignantSuivi.prenom : 'Non assigné' }}</td>
                        <td>{{ stage.EnseignantVisite ? stage.EnseignantVisite.nom ~ ' ' ~ stage.EnseignantVisite.prenom : 'Non assigné' }}</td>
                    </tr>
                {% else %}
                    <tr><td colspan="4">Aucun stage enregistré.</td></tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </main>
</body>
</html>