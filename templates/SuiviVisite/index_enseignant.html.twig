{# templates/SuiviVisite/index_enseignant.html.twig #}
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mes Suivis - La Chataigneraie</title>
    <link rel="stylesheet" href="{{ asset('CSS/dashboard.css') }}">
    <link rel="stylesheet" href="{{ asset('CSS/etudiant.css') }}">
</head>
<body>

    {# --- SIDEBAR --- #}
    <aside class="sidebar">
        {# ... (Même contenu que l'admin) ... #}
    </aside>

    <main class="main">
        <div class="page-header-flex">
            <div>
                <h1>Mes Interventions</h1>
                <p>Liste personnalisée de vos suivis et visites.</p>
            </div>
        </div>

        {# --- TABLEAU DES VISITES (Avec Adresse) --- #}
        <h2 style="margin: 20px 0 10px 0; color: #2d3436;">Mes visites à effectuer</h2>
        <div class="section-card table-wrapper">
            <table class="students-table">
                <thead style="background-color: #ebfaf0;"> {# Couleur légère pour différencier #}
                    <tr>
                        <th>Étudiant</th>
                        <th>Entreprise</th>
                        <th>Lieu (Ville)</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% for stage in mesVisites %}
                    <tr>
                        <td>{{ stage.ETUID.ETUNom }} {{ stage.ETUID.ETUPrenom }}</td>
                        <td>{{ stage.ENTID.ENTNom }}</td>
                        <td>
                            {% if stage.ENTID and stage.ENTID.VILID %}
                                {# On accède au nom de la ville via VILID #}
                                {{ stage.ENTID.VILID.VILNom }} ({{ stage.ENTID.ENTAdresse }})
                            {% else %}
                                {# Sécurité au cas où l'entreprise ou la ville est manquante #}
                                {{ stage.ENTID ? stage.ENTID.ENTNom : 'Entreprise inconnue' }} (Lieu non renseigné)
                            {% endif %}
                        </td>
                        <td>
                             <a href="{{ path('app_stage_update', {'id': stage.id}) }}" class="action-link edit" title="Saisir Visite">
                                <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                                </svg>
                            </a>
                        </td>
                    </tr>
                {% else %}
                    <tr><td colspan="4">Aucune visite à votre nom.</td></tr>
                {% endfor %}
                </tbody>
            </table>
        </div>

        {# --- TABLEAU DES SUIVIS --- #}
        <h2 style="margin: 30px 0 10px 0; color: #2d3436;">Mes suivis pédagogiques</h2>
        <div class="section-card table-wrapper">
            <table class="students-table">
                <thead>
                    <tr>
                        <th>Étudiant</th>
                        <th>Entreprise</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% for stage in mesSuivis %}
                    <tr>
                        <td>{{ stage.ETUID.ETUNom }} {{ stage.ETUID.ETUPrenom }}</td>
                        <td>{{ stage.ENTID.ENTNom }}</td>
                        <td>
                             <a href="{{ path('app_stage_update', {'id': stage.id}) }}" class="action-link show" title="Bilan">
                                <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2"/><rect x="9" y="3" width="6" height="4" rx="1"/>
                                </svg>
                            </a>
                        </td>
                    </tr>
                {% else %}
                    <tr><td colspan="3">Aucun suivi à votre nom.</td></tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </main>
</body>
</html>