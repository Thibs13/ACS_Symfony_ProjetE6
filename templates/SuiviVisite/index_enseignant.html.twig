<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Stages - La Chataigneraie</title>
    <link rel="stylesheet" href="{{ asset('CSS/dashboard.css') }}">
    <link rel="stylesheet" href="{{ asset('CSS/etudiant.css') }}">
</head>
<body>

<aside class="sidebar">
    <div class="sidebar-logo">
        <div class="logo-badge">
            <img src="{{ asset('Image/campus-logo.png') }}" alt="Logo Campus La Chataigneraie" />
        </div>
        <h2>La Chataigneraie</h2>
        <p>Suivi des stages</p>
    </div>

    <nav class="sidebar-nav">
        <a href="{{ path('app_dashboard') }}" class="nav-item">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/>
                <rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/>
            </svg>
            Tableau de bord
        </a>
        {% if role == 1 %}
            <a href="{{ path('app_etudiant_read') }}" class="nav-item">
                <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/>
                    <path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/>
                </svg>
                Étudiants
            </a>
            <a href="{{ path('app_promotions_read') }}" class="nav-item">
                <svg fill="none" viewbox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/>
                    <path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/>
                </svg>
                Promotions
            </a>
        {% endif %}
        <a href="{{ path('app_entreprise_read') }}" class="nav-item">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <rect x="2" y="7" width="20" height="14" rx="2"/>
                <path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2"/>
            </svg>
            Entreprises
        </a>
        {% if role == 1 %}
            <a href="{{ path('app_secteuractivite_read') }}" class="nav-item">
                <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <rect x="2" y="7" width="20" height="14" rx="2"/>
                    <path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2"/>
                </svg>
                Secteur d'activité
            </a>
        {% endif %}
        <a href="{{ path('app_stage_read') }}" class="nav-item">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <rect x="3" y="3" width="18" height="18" rx="2"/>
                <path d="M3 9h18M9 21V9"/>
            </svg>
            Stages
        </a>
        <a href="{{ path('app_suivi_visite') }}" class="nav-item active">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2"/>
                <rect x="9" y="3" width="6" height="4" rx="1"/>
                <path d="M9 12h6M9 16h4"/>
            </svg>
            Suivi &amp; Visites
        </a>
        {% if role == 1 %}
            <a href="{{ path('app_utilisateurs') }}" class="nav-item">
                <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/>
                    <circle cx="12" cy="7" r="4"/>
                </svg>
                Utilisateurs
            </a>
        {% endif %}
        <a href="#" class="nav-item">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/>
                <polyline points="7 10 12 15 17 10"/>
                <line x1="12" y1="15" x2="12" y2="3"/>
            </svg>
            Exports
        </a>
    </nav>

    <div class="sidebar-footer">
        <a href="{{ path('app_deco') }}" class="btn-deco">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/>
                <polyline points="16 17 21 12 16 7"/>
                <line x1="21" y1="12" x2="9" y2="12"/>
            </svg>
            Deconnexion
        </a>
    </div>
</aside>

    <main class="main">
        <div class="page-header-flex">
            <div>
                <h1>Mes Interventions</h1>
                <p>Liste personnalisée de vos suivis et visites.</p>
            </div>
        </div>

        {# --- TABLEAU DES VISITES (Avec Adresse) --- #}
        <h2 style="margin: 20px 0 10px 0; color: #2d3436;">Mes visites à effectuer</h2>
        <div class="section-card table-wrapper">
            <table class="students-table">
                <thead style="background-color: #ebfaf0;"> {# Couleur légère pour différencier #}
                    <tr>
                        <th>Étudiant</th>
                        <th>Entreprise</th>
                        <th>Lieu (Ville)</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% for stage in mesVisites %}
                    <tr>
                        <td>{{ stage.ETUID.ETUNom }} {{ stage.ETUID.ETUPrenom }}</td>
                        <td>{{ stage.ENTID.ENTNom }}</td>
                        <td>
                            {% if stage.ENTID and stage.ENTID.VILID %}
                                {# On accède au nom de la ville via VILID #}
                                {{ stage.ENTID.VILID.VILNom }} ({{ stage.ENTID.ENTAdresse }})
                            {% else %}
                                {# Sécurité au cas où l'entreprise ou la ville est manquante #}
                                {{ stage.ENTID ? stage.ENTID.ENTNom : 'Entreprise inconnue' }} (Lieu non renseigné)
                            {% endif %}
                        </td>
                        <td>
                             <a href="{{ path('app_stage_update', {'id': stage.id}) }}" class="action-link edit" title="Saisir Visite">
                                <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                                </svg>
                            </a>
                        </td>
                    </tr>
                {% else %}
                    <tr><td colspan="4">Aucune visite à votre nom.</td></tr>
                {% endfor %}
                </tbody>
            </table>
        </div>

        {# --- TABLEAU DES SUIVIS --- #}
        <h2 style="margin: 30px 0 10px 0; color: #2d3436;">Mes suivis pédagogiques</h2>
        <div class="section-card table-wrapper">
            <table class="students-table">
                <thead>
                    <tr>
                        <th>Étudiant</th>
                        <th>Entreprise</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% for stage in mesSuivis %}
                    <tr>
                        <td>{{ stage.ETUID.ETUNom }} {{ stage.ETUID.ETUPrenom }}</td>
                        <td>{{ stage.ENTID.ENTNom }}</td>
                        <td>
                             <a href="{{ path('app_stage_update', {'id': stage.id}) }}" class="action-link show" title="Bilan">
                                <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2"/><rect x="9" y="3" width="6" height="4" rx="1"/>
                                </svg>
                            </a>
                        </td>
                    </tr>
                {% else %}
                    <tr><td colspan="3">Aucun suivi à votre nom.</td></tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </main>
</body>
</html>