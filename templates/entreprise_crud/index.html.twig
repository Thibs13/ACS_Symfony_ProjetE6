<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Entreprises</title>
    <link rel="stylesheet" href="{{ asset('CSS/dashboard.css') }}">
    <link rel="stylesheet" href="{{ asset('CSS/etudiant.css') }}">
</head>
<body>

<aside class="sidebar">
    <div class="sidebar-logo">
        <div class="logo-badge">
            <img src="{{ asset('Image/campus-logo.png') }}" alt="Logo Campus La Chataigneraie" />
        </div>
        <h2>La Chataigneraie</h2>
        <p>Liste d'entreprises</p>
    </div>

    <nav class="sidebar-nav">
        <a href="{{ path('app_dashboard') }}" class="nav-item">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/>
                <rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/>
            </svg>
            Tableau de bord
        </a>
        <a href="{{ path('app_etudiant_read') }}" class="nav-item">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/>
                <path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/>
            </svg>
            Étudiants
        </a>
        <a href="{{ path('app_entreprise_read') }}" class="nav-item active">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <rect x="2" y="7" width="20" height="14" rx="2"/>
                <path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2"/>
            </svg>
            Entreprises
        </a>
        <a href="{{ path('app_stage_read') }}" class="nav-item">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <rect x="3" y="3" width="18" height="18" rx="2"/>
                <path d="M3 9h18M9 21V9"/>
            </svg>
            Stages
        </a>
        <a href="#" class="nav-item">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2"/>
                <rect x="9" y="3" width="6" height="4" rx="1"/>
                <path d="M9 12h6M9 16h4"/>
            </svg>
            Suivi &amp; Visites
        </a>
        <a href="{{ path('app_utilisateurs') }}" class="nav-item">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/>
                <circle cx="12" cy="7" r="4"/>
            </svg>
            Utilisateurs
        </a>
        <a href="#" class="nav-item">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/>
                <polyline points="7 10 12 15 17 10"/>
                <line x1="12" y1="15" x2="12" y2="3"/>
            </svg>
            Exports
        </a>
    </nav>

    <div class="sidebar-footer">
        <a href="{{ path('app_deco') }}" class="btn-deco">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/>
                <polyline points="16 17 21 12 16 7"/>
                <line x1="21" y1="12" x2="9" y2="12"/>
            </svg>
            Deconnexion
        </a>
    </div>
</aside>

<main class="main">
    <div class="page-header-flex">
        <div>
            <h1>Gestion des entreprises</h1>
            <p>Consulter, modifier et creer les fiches d'entreprises.</p>
        </div>
        <a href="{{ path('app_entreprise_create') }}" class="btn-add">Ajouter une entreprise</a>
    </div>

    <div class="section-card table-wrapper">
        <table class="table">
            <thead>
                <tr>
                    <th>Id</th>
                    <th>Nom</th>
                    <th>Telephone</th>
                    <th>Email</th>
                    <th>Ville</th>
                    <th>actions</th>
                </tr>
            </thead>
            <tbody>
            {% for entreprise in entreprises %}
                <tr>
                    <td>{{ entreprise.id }}</td>
                    <td>{{ entreprise.ENTNom }}</td>
                    <td>{{ entreprise.ENTTelephone }}</td>
                    <td>{{ entreprise.ENTEmail }}</td>
                    <td>{{ entreprise.VILID.VILnom }}</td>
                    <td>
                        <div class="table-actions">
                            <a href="{{ path('app_entreprise_show', {'id': entreprise.id}) }}"
                               class="action-link show js-view-btn"
                               title="Voir"
                               data-id="{{ entreprise.id }}"
                               data-nom="{{ entreprise.ENTNom }}"
                               data-telephone="{{ entreprise.ENTTelephone }}"
                               data-email="{{ entreprise.ENTEmail }}"
                               data-ville="{{ entreprise.VILID.VILnom }}"
                               data-cp="{{ entreprise.VILID.VILCP }}">
                                <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                                </svg>
                            </a>
                            <a href="{{ path('app_entreprise_update', {'id': entreprise.id}) }}"
                               class="action-link edit js-edit-btn"
                               title="Modifier"
                               data-id="{{ entreprise.id }}"
                               data-nom="{{ entreprise.ENTNom }}"
                               data-telephone="{{ entreprise.ENTTelephone }}"
                               data-email="{{ entreprise.ENTEmail }}"
                               data-ville="{{ entreprise.VILID.id }}"
                               data-token="{{ csrf_token('edit_entreprise_' ~ entreprise.id) }}">
                                <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                                </svg>
                            </a>
                        </div>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="6">Aucune entreprise trouvée</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</main>







<!-- Modal de creation d'etudiant -->
<div id="entrepriseModal" class="modal-overlay" style="display: none;">
    <div class="modal-popup">
        <div class="modal-popup-header">
            <h2>Ajouter une entreprise</h2>
            <button type="button" class="modal-close-btn" id="modalCloseBtn">&times;</button>
        </div>
        <!-- Formulaire envoye en POST pour inserer en base -->
        <form method="post" action="{{ path('app_entreprise_read') }}">
            <input type="hidden" name="_token" value="{{ csrf_token('create_entreprise') }}">
            <div class="form-group">
                <label>Nom</label>
                <input type="text" name="nom" required>
            </div>
            <div class="form-group">
                <label>Téléphone</label>
                <input type="text" name="telephone" required>
            </div>
            <div class="form-group">
                <label>Email</label>
                <input type="email" name="email" required>
            </div>
            <div class="form-group">
                <label>Ville</label>
                <select name="ville" required>
                    <option value="">-- Selectionnez --</option>
                    {% for ville in villes %}
                        <option value="{{ ville.id }}">{{ ville.VILNom }}</option>
                    {% endfor %}
                </select>
            </div>
            <div class="modal-actions">
                <button type="button" class="btn-cancel" id="modalCancelBtn">Annuler</button>
                <button type="submit" class="btn-submit">Ajouter</button>
            </div>
        </form>
    </div>
</div>








<!-- Modal de visualisation d'etudiant -->
<div id="viewEntrepriseModal" class="modal-overlay" style="display: none;">
    <div class="modal-popup">
        <div class="modal-popup-header">
            <h2>Voir l'entreprise</h2>
            <button type="button" class="modal-close-btn" id="viewModalCloseBtn">&times;</button>
        </div>

        <div class="student-info">
            <p><strong>ID :</strong> <span id="viewId">-</span></p>
            <p><strong>Nom :</strong> <span id="viewNom">-</span></p>
            <p><strong>Téléphone :</strong> <span id="viewTelephone">-</span></p>
            <p><strong>Email :</strong> <span id="viewEmail">-</span></p>
            <p><strong>Ville :</strong> <span id="viewVille">-</span></p>
            <p><strong>Code Postal :</strong> <span id="viewCP">-</span></p>

        </div>

        <div class="modal-actions">
            <button type="button" class="btn-cancel" id="viewModalCloseBtnBottom">Fermer</button>
        </div>
    </div>
</div>







<!-- Modal de modification d'etudiant -->
<div id="editEntrepriseModal" class="modal-overlay" style="display: none;">
    <div class="modal-popup">
        <div class="modal-popup-header">
            <h2>Modifier l'entreprise</h2>
            <button type="button" class="modal-close-btn" id="editModalCloseBtn">&times;</button>
        </div>

        <form id="editEntrepriseForm" method="post" action="">
            <input type="hidden" name="_token" id="editTokenInput" value="">

            <div class="form-group">
                <label>Nom</label>
                <input type="text" name="nom" id="editNom" required>
            </div>

            <div class="form-group">
                <label>Téléphone</label>
                <input type="int" name="telephone" id="editTelephone" required>
            </div>

            <div class="form-group">
                <label>Email</label>
                <input type="email" name="email" id="editEmail" required>
            </div>

            <div class="form-group">
                <label>Ville</label>
                <select name="ville" id="editVille" required>
                    <option value="">-- Selectionnez --</option>
                    {% for ville in villes %}
                        <option value="{{ ville.id }}">{{ ville.VILNom }}</option>
                    {% endfor %}
                </select>
            </div>

            <div class="modal-actions">
                <button type="button" class="btn-cancel" id="editModalCancelBtn">Annuler</button>
                <button type="submit" class="btn-submit">Enregistrer</button>
            </div>
        </form>
    </div>
</div>






<script>
// Recupere les 3 modals
const addModal = document.getElementById('entrepriseModal');
const viewModal = document.getElementById('viewEntrepriseModal');
const editModal = document.getElementById('editEntrepriseModal');

// Outils pour ouvrir/fermer une modal
function openModal(modal) {
    modal.style.display = 'flex';
}

function closeModal(modal) {
    modal.style.display = 'none';
}

// creation d'un nouvel etudiant
document.querySelector('.btn-add').addEventListener('click', function(event) {
    event.preventDefault();
    openModal(addModal);
});

document.getElementById('modalCloseBtn').addEventListener('click', function() {
    closeModal(addModal);
});

document.getElementById('modalCancelBtn').addEventListener('click', function() {
    closeModal(addModal);
});

// visualisation d'une entreprise
document.querySelectorAll('.js-view-btn').forEach(function(button) {
    button.addEventListener('click', function(event) {
        event.preventDefault();

        document.getElementById('viewId').textContent = this.dataset.id;
        document.getElementById('viewNom').textContent = this.dataset.nom;
        document.getElementById('viewTelephone').textContent = this.dataset.telephone;
        document.getElementById('viewEmail').textContent = this.dataset.email;
        document.getElementById('viewVille').textContent = this.dataset.ville;
        document.getElementById('viewCP').textContent = this.dataset.cp;

        openModal(viewModal);
    });
});

document.getElementById('viewModalCloseBtn').addEventListener('click', function() {
    closeModal(viewModal);
});

document.getElementById('viewModalCloseBtnBottom').addEventListener('click', function() {
    closeModal(viewModal);
});

// modification d'une entreprise
document.querySelectorAll('.js-edit-btn').forEach(function(button) {
    button.addEventListener('click', function(event) {
        event.preventDefault();

        // Remplit le formulaire avec les donnees de la ligne
        document.getElementById('editEntrepriseForm').action = this.getAttribute('href');
        document.getElementById('editTokenInput').value = this.dataset.token;
        document.getElementById('editNom').value = this.dataset.nom;
        document.getElementById('editTelephone').value = this.dataset.telephone;
        document.getElementById('editEmail').value = this.dataset.email;
        document.getElementById('editVille').value = this.dataset.villeId;

        openModal(editModal);
    });
});

document.getElementById('editModalCloseBtn').addEventListener('click', function() {
    closeModal(editModal);
});

document.getElementById('editModalCancelBtn').addEventListener('click', function() {
    closeModal(editModal);
});

// Ferme toutes les modals avec la touche Echap
document.addEventListener('keydown', function(event) {
    if (event.key === 'Escape') {
        closeModal(addModal);
        closeModal(viewModal);
        closeModal(editModal);
    }
});
</script>
</body>
</html>