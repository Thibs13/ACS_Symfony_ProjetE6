<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Modifier l'utilisateur – La Châtaigneraie</title>
        
        {# on importe les feuilles de style pour le design global et les formulaires #}
        <link rel="stylesheet" href="{{ asset('CSS/dashboard.css') }}">
        <link rel="stylesheet" href="{{ asset('CSS/utilisateur.css') }}">
        <link rel="stylesheet" href="{{ asset('CSS/utilisateur_form.css') }}">
    </head>
    <body>

        {# la barre latérale (sidebar) qui contient le logo et le menu de navigation #}
        <aside class="sidebar">
            <div class="sidebar-logo">
                <div class="logo-badge">
                    <img src="{{ asset('Image/campus-logo.png') }}" alt="Logo Campus La Chataigneraie"/>
                </div>
                <h2>La Châtaigneraie</h2>
                <p>Suivi des stages</p>
            </div>

            {% include 'navigation.html.twig' with {
				'namePage' : 'entreprise' 
				} %}

            {# bouton de déconnexion en bas de la barre latérale #}
            <div class="sidebar-footer">
                <a href="{{ path('app_deco') }}" class="btn-deco">
                    <svg fill="none" viewbox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/>
                        <polyline points="16 17 21 12 16 7"/>
                        <line x1="21" y1="12" x2="9" y2="12"/>
                    </svg>
                    Déconnexion
                </a>
            </div>
        </aside>

        {# la zone principale de la page (main) #}
        <main class="main">

            {# en-tête de la page avec le titre et le bouton de retour #}
            <div class="page-header-flex">
                <div>
                    <h1>Modifier l'entreprise</h1>
                    <p>Mise à jour des informations</p>
                </div>

                <a href="{{ path('app_entreprise_read') }}" class="btn-outline-back">
                    <svg fill="none" viewbox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
                    </svg>
                    Retour à la liste
                </a>
            </div>

            {# conteneur du formulaire de modification #}
            <div class="form-wrapper">
                <div class="form-card">
                    {# on inclut le fichier Twig qui contient les champs du formulaire d'entreprise #}
                    {{ include('entreprise_crud/form.html.twig', {'button_label': 'Mettre à jour'}) }}

                    {# on inclut aussi le petit formulaire séparé pour la suppression #}
                    <div class="delete-simple-wrapper delete-form-wrapper">
                        {{ include('entreprise_crud/delete_form.html.twig') }}
                    </div>
                </div>
            </div>

        </main>
    </body>
</html>