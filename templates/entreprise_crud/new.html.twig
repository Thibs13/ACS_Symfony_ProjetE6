<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Nouvel Utilisateur – La Châtaigneraie</title>
        {# on importe les styles nécessaires pour que la page soit jolie et cohérente avec le reste du site #}
        <link rel="stylesheet" href="{{ asset('CSS/dashboard.css') }}">
        <link rel="stylesheet" href="{{ asset('CSS/utilisateur.css') }}">
        <link rel="stylesheet" href="{{ asset('CSS/utilisateur_form.css') }}">
    </head>
    <body>

        {# la barre latérale reste identique pour que l'utilisateur ne perde pas ses repères #}
        <aside class="sidebar">
            <div class="sidebar-logo">
                <div class="logo-badge">
                    <img src="{{ asset('Image/campus-logo.png') }}" alt="Logo Campus La Chataigneraie"/>
                </div>
                <h2>La Châtaigneraie</h2>
                <p>Suivi des stages</p>
            </div>

            {% include 'navigation.html.twig' with {
				'namePage' : 'entreprise' 
				} %}

            <div class="sidebar-footer">
                <a href="{{ path('app_deco') }}" class="btn-deco">
                    <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/>
                        <polyline points="16 17 21 12 16 7"/>
                        <line x1="21" y1="12" x2="9" y2="12"/>
                    </svg>
                    Déconnexion
                </a>
            </div>
        </aside>

        {# le contenu principal de la page #}
        <main class="main">

            {# l'en-tête explique clairement l'action en cours : l'ajout d'une entreprise #}
            <div class="page-header-flex">
                <div>
                    <h1>Ajouter une nouvelle entreprise</h1>
                    <p>Remplissez le formulaire ci-dessous pour ajouter une entreprise</p>
                </div>
                
                {# bouton pour annuler et revenir rapidement à la liste sans rien enregistrer #}
                <a href="{{ path('app_entreprise_read') }}" class="btn-outline-back">
                    <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
                    </svg>
                    Retour à la liste
                </a>
            </div>

            {# zone centrale qui contient le formulaire proprement dit #}
            <div class="form-wrapper">
                <div class="form-card">
                    {# on appelle le fichier form.html.twig qui contient tous les champs de saisie (nom, email, etc.) #}
                    {{ include('entreprise_crud/form.html.twig') }}
                </div>
            </div>

        </main>
    </body>
</html>