{# cette balise ouvre le formulaire et gère automatiquement l'envoi des données (POST) #}
{{ form_start(form) }}

    {{ form_errors(form) }}

    <div class="date-row">
        {{ form_row(form.ENT_Nom, {'label': 'Nom de l\'entreprise *'}) }}
        {{ form_row(form.ENT_Telephone, {'label': 'Téléphone *'}) }}
        {{ form_row(form.ENT_Email, {'label': 'Email *'}) }}
        {{ form_row(form.ENT_Adresse, {'label': 'Adresse *'}) }}
        {{ form_row(form.VIL_ID, {'label': 'Ville *', 'placeholder': 'Sélectionnez une ville'}) }}
        {{ form_row(form.secteur, {'label': 'Secteur d\'activité *', 'placeholder': 'Sélectionnez un secteur'}) }}
    </div>

    {# le bouton de validation dont le texte change selon qu'on crée ou qu'on modifie #}
    <button class="btn">{{ button_label|default('Sauvegarder') }}</button>

{# cette balise ferme le formulaire et ajoute discrètement des champs de sécurité (CSRF) #}
{{ form_end(form) }}