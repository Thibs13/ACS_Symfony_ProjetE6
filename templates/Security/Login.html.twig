{% extends 'base.html.twig' %}

{% block title %}Connexion - Campus La Châtaigneraie{% endblock %}

{% block body %}
<div class="auth-page">
    <div class="auth-container">
        {# Logo et nom du campus #}
        <div class="auth-header">
            <div class="campus-logo">
                <svg viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <defs>
                        <linearGradient id="circleGradient" x1="0%" y1="0%" x2="100%" y2="100%">
                            <stop offset="0%" stop-color="#14b8a6" />
                            <stop offset="50%" stop-color="#06b6d4" />
                            <stop offset="100%" stop-color="#0ea5e9" />
                        </linearGradient>
                        <linearGradient id="treeGradient" x1="0%" y1="0%" x2="100%" y2="100%">
                            <stop offset="0%" stop-color="#f59e0b" />
                            <stop offset="100%" stop-color="#ef4444" />
                        </linearGradient>
                    </defs>
                    <circle cx="50" cy="50" r="48" fill="url(#circleGradient)" opacity="0.15" />
                    <circle cx="50" cy="50" r="48" stroke="url(#circleGradient)" stroke-width="2" fill="none" />
                    <rect x="46" y="55" width="8" height="20" rx="2" fill="#4b5563" />
                    <circle cx="50" cy="35" r="12" fill="url(#treeGradient)" opacity="0.9" />
                    <circle cx="38" cy="50" r="10" fill="url(#treeGradient)" opacity="0.8" />
                    <circle cx="62" cy="50" r="10" fill="url(#treeGradient)" opacity="0.8" />
                    <circle cx="50" cy="28" r="2" fill="#fbbf24" />
                    <circle cx="42" cy="45" r="1.5" fill="#fbbf24" />
                    <circle cx="58" cy="45" r="1.5" fill="#fbbf24" />
                </svg>
            </div>
            <div class="campus-info">
                <div class="campus-name">Campus La Châtaigneraie</div>
                <div class="campus-subtitle">Rouen Normandie Tech & Pro School</div>
            </div>
        </div>

        {# Carte de connexion #}
        <div class="auth-card">
            <div class="auth-card-header">
                <h2 class="auth-title">Connexion</h2>
                <p class="auth-subtitle">Accédez à votre espace</p>
            </div>

            {# Messages flash #}
            {% for message in app.flashes('error') %}
                <div class="alert alert-danger" role="alert">
                    {{ message }}
                </div>
            {% endfor %}

            {% for message in app.flashes('success') %}
                <div class="alert alert-success" role="alert">
                    {{ message }}
                </div>
            {% endfor %}

            <form method="post" action="{{ path('app_login') }}">
                {# Champ Identifiant #}
                <div class="mb-4">
                    <label for="username" class="form-label">Identifiant</label>
                    <div class="input-with-icon">
                        <svg class="input-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                        </svg>
                        <input 
                            type="text" 
                            class="form-control form-control-icon" 
                            id="username" 
                            name="_username" 
                            value="{{ last_username }}" 
                            placeholder="Entrez votre identifiant"
                            required
                        >
                    </div>
                </div>

                {# Champ Mot de passe #}
                <div class="mb-4">
                    <label for="password" class="form-label">Mot de passe</label>
                    <div class="input-with-icon">
                        <svg class="input-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                        </svg>
                        <input 
                            type="password" 
                            class="form-control form-control-icon" 
                            id="password" 
                            name="_password" 
                            placeholder="Entrez votre mot de passe"
                            required
                        >
                    </div>
                </div>

                {# Info de test #}
                <div class="test-info">
                    <p>
                        <strong>Mode test :</strong> Utilisez les identifiants 
                        <strong>Admin</strong> / <strong>Admin</strong> pour vous connecter.
                    </p>
                </div>

                <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                {# Bouton de connexion #}
                <button type="submit" class="btn btn-primary-gradient w-100">
                    <span>Se connecter</span>
                    <svg class="btn-arrow" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
                    </svg>
                </button>

                {# Lien vers la création de compte #}
                <div class="auth-switch">
                    <a href="{{ path('app_register') }}">
                        Pas encore de compte ? <span>Créer un compte</span>
                    </a>
                </div>
            </form>
        </div>

        {# Footer #}
        <div class="auth-footer">
            <a href="https://www.la-chataigneraie.org" target="_blank" rel="noopener noreferrer">
                www.la-chataigneraie.org
            </a>
        </div>
    </div>
</div>
{% endblock %}
