{# templates/accueil/index.html.twig #}
{% extends 'base.html.twig' %}

{% block body %}
    <div class="fond accueil">
        <div class="logo">
            {# Utilise asset() pour que le chemin soit toujours correct #}
            <img src="{{ asset('Asset/logo.svg') }}" alt="Logo" style="max-width: 180px;" />
        </div>

        <div class="login-box">
            {# Affichage des erreurs envoyées manuellement par le Controller #}
            {% if erreur %}
                <div class="erreur" style="color: red; margin-bottom: 10px;">
                    {{ erreur }}
                </div>
            {% endif %}

            {# Affichage des messages Flash (ex: succès de l'inscription) #}
            {% for message in app.flashes('success') %}
                <div class="success" style="color: green; margin-bottom: 10px;">
                    {{ message }}
                </div>
            {% endfor %}

            {{ form_start(form) }}
                <div class="marge-basse">
                    {{ form_label(form.Login, 'Login :') }}
                    {{ form_widget(form.Login) }}
                </div>

                <div class="marge-basse">
                    {{ form_label(form.MotDePasse, 'Mot de passe :') }}
                    {{ form_widget(form.MotDePasse) }}
                </div>

                <div class="marge-basse align-centre">
                    <a href="{{ path('app_inscription') }}">Créer un compte</a>
                </div>

                <div class="align-centre">
                    {# Le style est déjà géré dans le AccueilType, mais on peut forcer ici si besoin #}
                    {{ form_widget(form.Save) }}
                </div>
            {{ form_end(form) }}
        </div>
    </div>

    {# On vérifie que le fichier existe bien dans templates/footer/index.html.twig #}
    
{% endblock %}