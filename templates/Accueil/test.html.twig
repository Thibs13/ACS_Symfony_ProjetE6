{% extends 'base.html.twig' %}
{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/style.css') }}">
{% endblock %}

{% block title %}Connexion - Campus{% endblock %}

{% block body %}
<div class="auth-wrapper">
    <div class="auth-card">
        
        <header class="auth-header">
            <img src="{{ asset('Image/campus-logo.png') }}" alt="Logo" class="auth-logo" />
            <h1>Bienvenue</h1>
            <p>Connectez-vous à votre espace</p>
        </header>

        <div class="auth-body">
            {% if erreur %}
                <div class="alert alert-danger">
                    <i class="fas fa-exclamation-circle"></i> {{ erreur }}
                </div>
            {% endif %}

            {% for message in app.flashes('success') %}
                <div class="alert alert-success">
                    <i class="fas fa-check-circle"></i> {{ message }}
                </div>
            {% endfor %}

            {{ form_start(form, {'attr': {'class': 'auth-form'}}) }}
                <div class="form-group">
                    {{ form_label(form.login, 'Identifiant') }}
                    <div class="input-wrapper">
                        {{ form_widget(form.login, {'attr': {'placeholder': 'Ex: jdupont'}}) }}
                    </div>
                </div>

                <div class="form-group">
                    {{ form_label(form.password, 'Mot de passe') }}
                    <div class="input-wrapper">
                        {{ form_widget(form.password, {'attr': {'placeholder': '••••••••'}}) }}
                    </div>
                </div>

                <button type="submit" class="btn-submit">
                    <span>Se connecter</span>
                    <svg class="btn-arrow" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
                    </svg>
                </button>

                <div class="auth-footer">
                    <p>Pas encore de compte ? <a href="{{ path('app_inscription') }}">Créer un compte</a></p>
                </div>

            {# MODIFICATION ICI : On empêche l'affichage du bouton automatique #}
            {{ form_end(form, {'render_rest': false}) }}

        </div>
    </div>
</div>
{% endblock %}