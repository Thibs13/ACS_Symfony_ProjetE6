<!DOCTYPE html>

<title>Etudiant index</title>

{% block body %}
    <h1>Etudiant index</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>ETU_Nom</th>
                <th>ETU_Prenom</th>
                <th>ETU_Promotion</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for etudiant in etudiants %}
            <tr>
                <td>{{ etudiant.id }}</td>
                <td>{{ etudiant.ETUNom }}</td>
                <td>{{ etudiant.ETUPrenom }}</td>
                <td>{{ etudiant.ETUPromotion }}</td>
                <td>
                    <a href="{{ path('app_etudiant_c_r_u_d_show', {'id': etudiant.id}) }}">show</a>
                    <a href="{{ path('app_etudiant_c_r_u_d_edit', {'id': etudiant.id}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="5">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_etudiant_c_r_u_d_new') }}">Create new</a>
{% endblock %}
