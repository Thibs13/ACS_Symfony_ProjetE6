<!DOCTYPE html>

<title>Etudiant</title>

{% block body %}
    <h1>Etudiant</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id : </th>
                <td>{{ etudiant.id }}</td>
            </tr>
            <tr>
                <th>Nom : </th>
                <td>{{ etudiant.ETUNom }}</td>
            </tr>
            <tr>
                <th>Prenom : </th>
                <td>{{ etudiant.ETUPrenom }}</td>
            </tr>
            <tr>
                <th>Promotion : </th>
                <td>{{ etudiant.ETUPromotion }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_etudiant_read') }}">Retour</a>

    <a href="{{ path('app_etudiant_update', {'id': etudiant.id}) }}">Modifier</a>

    {{ include('etudiant_crud/_delete_form.html.twig') }}
{% endblock %}
