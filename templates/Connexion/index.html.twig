<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Connexion | Campus La Chataigneraie</title>
    <link rel="stylesheet" href="{{ asset('CSS/connexion.css') }}">
</head>
<body>
    <div class="accueil-wrapper">
        <div class="login-card">
            <header class="logo-container">
                <img src="{{ asset('Image/campus-logo.png') }}" alt="Logo du Campus" />
            </header>

            {# Gestion des messages d'erreur et de succes #}
            {% if erreur %}
                <div class="alert alert-error">
                    {{ erreur }}
                </div>
            {% endif %}

            {% for message in app.flashes('success') %}
                <div class="alert alert-success">
                    {{ message }}
                </div>
            {% endfor %}

            {# Debut du formulaire #}
            {{ form_start(form) }}
                <div class="form-group">
                    {{ form_label(form.login, 'Login :') }}
                    {{ form_widget(form.login) }}
                </div>

                <div class="form-group">
                    {{ form_label(form.password, 'Mot de passe :') }}
                    {{ form_widget(form.password) }}
                </div>
            {{ form_end(form) }}

            <div class="links-container">
                <a href="{{ path('app_inscription') }}">Creer un compte</a>
            </div>
        </div>
    </div>
</body>
</html>