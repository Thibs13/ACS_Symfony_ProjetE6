<!DOCTYPE html>
<html lang="fr">
	<head>
		<meta charset="UTF-8">
		<meta name="viewport" content="width=device-width, initial-scale=1.0">
		<title>Tableau de bord – La Châtaigneraie</title>
		<link rel="stylesheet" href="{{ asset('CSS/dashboard.css') }}">
	</head>
	<body>

		<!-- ══ SIDEBAR ══ -->
		<aside class="sidebar">
			<div class="sidebar-logo">
				<div class="logo-badge">
					<img src="{{ asset('Image/campus-logo.png') }}" alt="Logo Campus La Chataigneraie"/>
				</div>
				<h2>La Châtaigneraie</h2>
				<p>Suivi des stages</p>
			</div>

			{% include 'navigation.html.twig' with {
                'namePage' : 'dashboard' 
                } %}

			<div class="sidebar-footer">
				<a href="{{ path('app_deco') }}" class="btn-deco">
					<svg fill="none" viewbox="0 0 24 24" stroke="currentColor" stroke-width="2">
						<path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/>
						<polyline points="16 17 21 12 16 7"/>
						<line x1="21" y1="12" x2="9" y2="12"/>
					</svg>
					Déconnexion
				</a>
			</div>
		</aside>

		<!-- ══ MAIN CONTENT ══ -->
		<main class="main">

			<div class="page-header">
				<h1>Tableau de bord</h1>
				<p>Vue d'ensemble du suivi des stages BTS SIO</p>
			</div>

			<!-- Stat cards -->
			<div class="cards-grid">
				<div class="stat-card">
					<div class="stat-info">
						<p>Étudiants</p>
						<h2>{{ totalEtudiants }}</h2>
					</div>
					<div class="stat-icon icon-teal">
						<svg fill="none" viewbox="0 0 24 24" stroke="currentColor" stroke-width="2">
							<path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/>
							<circle cx="9" cy="7" r="4"/>
							<path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/>
						</svg>
					</div>
				</div>
				<div class="stat-card">
					<div class="stat-info">
						<p>Stages actifs</p>
						<h2>{{ totalStages }}</h2>
					</div>
					<div class="stat-icon icon-cyan">
						<svg fill="none" viewbox="0 0 24 24" stroke="currentColor" stroke-width="2">
							<rect x="2" y="7" width="20" height="14" rx="2"/>
							<path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2"/>
						</svg>
					</div>
				</div>
				<div class="stat-card">
					<div class="stat-info">
						<p>Entreprises partenaires</p>
						<h2>{{ totalEntreprises }}</h2>
					</div>
					<div class="stat-icon icon-amber">
						<svg fill="none" viewbox="0 0 24 24" stroke="currentColor" stroke-width="2">
							<rect x="3" y="3" width="18" height="18" rx="2"/>
							<path d="M3 9h18M9 21V9"/>
						</svg>
					</div>
				</div>
			</div>

			<!-- Actions rapides -->
			{% if role == 1 %}
				<div class="section-card">
					<h3>Actions rapides</h3>
					<div class="actions-grid">
						<a href="{{ path('app_etudiant_create') }}" class="action-btn btn-green">
							<svg fill="none" viewbox="0 0 24 24" stroke="currentColor" stroke-width="2">
								<path d="M16 21v-2a4 4 0 00-4-4H6a4 4 0 00-4 4v2"/>
								<circle cx="9" cy="7" r="4"/>
								<line x1="19" y1="8" x2="19" y2="14"/>
								<line x1="22" y1="11" x2="16" y2="11"/>
							</svg>
							Ajouter un étudiant
						</a>
						<a href="{{ path('app_entreprise_create') }}" class="action-btn btn-amber">
							<svg fill="none" viewbox="0 0 24 24" stroke="currentColor" stroke-width="2">
								<rect x="2" y="7" width="20" height="14" rx="2"/>
								<path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2"/>
							</svg>
							Ajouter une entreprise
						</a>
						<a href="{{ path('app_stage_create') }}" class="action-btn btn-dgreen">
							<svg fill="none" viewbox="0 0 24 24" stroke="currentColor" stroke-width="2">
								<rect x="3" y="3" width="18" height="18" rx="2"/>
								<path d="M3 9h18M9 21V9"/>
							</svg>
							Créer un stage
						</a>
					</div>
				</div>
			{% endif %}

			<!-- Prochains jalons -->
			<div class="section-card">
				<div class="section-header">
					<h3>
						<svg fill="none" viewbox="0 0 24 24" stroke="currentColor" stroke-width="2">
							<rect x="3" y="4" width="18" height="18" rx="2"/>
							<line x1="16" y1="2" x2="16" y2="6"/>
							<line x1="8" y1="2" x2="8" y2="6"/>
							<line x1="3" y1="10" x2="21" y2="10"/>
						</svg>
						Stages
					</h3>
					<a href="{{ path('app_stage_read') }}">Voir tout →</a>
				</div>
				<table class="table">
					<thead>
						<tr>
							<th>Date de début</th>
							<th>Date de fin</th>
							<th>Étudiant</th>
							<th>Entreprise</th>
							<th>actions</th>
						</tr>
					</thead>
					<tbody>
						{% for stage in stages %}
							<tr>
								<td>{{ stage.STADateDebut ? stage.STADateDebut|date('d-m-Y') : '' }}</td>
								<td>{{ stage.STADateFin ? stage.STADateFin|date('d-m-Y') : '' }}</td>
								<td>{{ stage.ETUID.ETUNom }}
									{{ stage.ETUID.ETUPrenom }}</td>
								<td>{{ stage.ENTID.ENTNom }}</td>
								<td>
									<div class="table-actions">
										<a href="{{ path('app_stage_show', {'id': stage.id}) }}" class="action-link show">Voir</a>
										<a href="{{ path('app_stage_update', {'id': stage.id}) }}" class="action-link edit" title="Modifier">
											<svg width="16" height="16" fill="none" viewbox="0 0 24 24" stroke="currentColor" stroke-width="2">
												<path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
											</svg>
										</a>
									</div>
								</td>
							</tr>
						{% else %}
							<tr>
								<td colspan="11">Aucun stage trouvé</td>
							</tr>
						{% endfor %}
					</tbody>
				</table>
			</div>

		</main>

	</body>
</html>
