<!DOCTYPE html>

<title>Historique</title>

{% block body %}
    <h1>Historique</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ historique.id }}</td>
            </tr>
            <tr>
                <th>HIS_Date</th>
                <td>{{ historique.HISDate ? historique.HISDate|date('Y-m-d') : '' }}</td>
            </tr>
            <tr>
                <th>HIS_AncienneValeur</th>
                <td>{{ historique.HISAncienneValeur }}</td>
            </tr>
            <tr>
                <th>HIS_NouvelleValeur</th>
                <td>{{ historique.HISNouvelleValeur }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_historique_index') }}">back to list</a>

    <a href="{{ path('app_historique_edit', {'id': historique.id}) }}">edit</a>

    {{ include('historique/_delete_form.html.twig') }}
{% endblock %}
