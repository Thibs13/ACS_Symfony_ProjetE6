<!DOCTYPE html>

<title>Historique index</title>

{% block body %}
    <h1>Historique index</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>HIS_Date</th>
                <th>HIS_AncienneValeur</th>
                <th>HIS_NouvelleValeur</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for historique in historiques %}
            <tr>
                <td>{{ historique.id }}</td>
                <td>{{ historique.HISDate ? historique.HISDate|date('Y-m-d') : '' }}</td>
                <td>{{ historique.HISAncienneValeur }}</td>
                <td>{{ historique.HISNouvelleValeur }}</td>
                <td>
                    <a href="{{ path('app_historique_show', {'id': historique.id}) }}">show</a>
                    <a href="{{ path('app_historique_edit', {'id': historique.id}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="5">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_historique_new') }}">Create new</a>
{% endblock %}
