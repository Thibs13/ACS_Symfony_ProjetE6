{% extends 'base.html.twig' %}

{% block title %}Gestion des Stages{% endblock %}

{% block body %}
<div class="container mt-4">
    <h1><i class="fas fa-clipboard-list"></i> Gestion des Stages</h1>
    <hr>

    {% if role == 1 %}
        {# --- VUE ADMINISTRATEUR --- #}
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2>Tous les stages enregistrés</h2>
            <a href="{{ path('app_stage_create') }}" class="btn btn-primary">Nouveau Stage</a>
        </div>

        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Étudiant</th>
                    <th>Entreprise</th>
                    <th>Visiteur</th>
                    <th>Suivi par</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for stage in allStages %}
                    <tr>
                        <td>{{ stage.ETUID.ETUNom }} {{ stage.ETUID.ETUPrenom }}</td>
                        <td>{{ stage.ENTID.ENTNom }}</td>
                        <td>{{ stage.EnseignantVisite ? stage.EnseignantVisite.nom : 'Non assigné' }}</td>
                        <td>{{ stage.EnseignantSuivi ? stage.EnseignantSuivi.nom : 'Non assigné' }}</td>
                        <td>
                            <a href="{{ path('app_stage_show', {'id': stage.id}) }}" class="btn btn-info btn-sm">Détails</a>
                            <a href="{{ path('app_stage_update', {'id': stage.id}) }}" class="btn btn-warning btn-sm">Modifier</a>
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>

    {% else %}
        {# --- VUE ENSEIGNANT --- #}
        
        {# Tableau 1 : Suivis #}
        <div class="card mb-5 shadow-sm">
            <div class="card-header bg-primary text-white">
                <h3 class="mb-0"><i class="fas fa-user-check"></i> Mes suivis pédagogiques</h3>
            </div>
            <div class="card-body">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>Étudiant</th>
                            <th>Entreprise</th>
                            <th>Bilan rempli ?</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for stage in stagesSuivi %}
                            <tr>
                                <td>{{ stage.ETUID.ETUNom }} {{ stage.ETUID.ETUPrenom }}</td>
                                <td>{{ stage.ENTID.ENTNom }}</td>
                                <td>
                                    {% if stage.STABilan is empty or stage.STABilan == 'Non' %}
                                        <span class="badge bg-danger">À remplir</span>
                                    {% else %}
                                        <span class="badge bg-success">Oui</span>
                                    {% endif %}
                                </td>
                                <td>
                                    <a href="{{ path('app_stage_update', {'id': stage.id}) }}" class="btn btn-sm btn-outline-primary">Mettre à jour</a>
                                </td>
                            </tr>
                        {% else %}
                            <tr><td colspan="4" class="text-center text-muted">Aucun étudiant en suivi pour le moment.</td></tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>

        {# Tableau 2 : Visites #}
        <div class="card shadow-sm">
            <div class="card-header bg-success text-white">
                <h3 class="mb-0"><i class="fas fa-map-marker-alt"></i> Mes visites à effectuer</h3>
            </div>
            <div class="card-body">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>Étudiant</th>
                            <th>Entreprise</th>
                            <th>Adresse</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for stage in stagesVisite %}
                            <tr>
                                <td>{{ stage.ETUID.ETUNom }} {{ stage.ETUID.ETUPrenom }}</td>
                                <td>{{ stage.ENTID.ENTNom }}</td>
                                <td>{{ stage.ENTID.ENTAdresse }}</td>
                                <td>
                                    <a href="{{ path('app_stage_update', {'id': stage.id}) }}" class="btn btn-sm btn-outline-success">Saisir visite</a>
                                </td>
                            </tr>
                        {% else %}
                            <tr><td colspan="4" class="text-center text-muted">Aucune visite prévue pour le moment.</td></tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    {% endif %}
</div>
{% endblock %}